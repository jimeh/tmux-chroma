{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "tmux-chroma-website",
  "compatibility_date": "2026-07-19",
  "workers_dev": false,
  "preview_urls": true,
  "routes": [
    {
      "pattern": "chroma.jimeh.dev",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist",
  },
}
